@page "/events"
@using Moeltid.Services.Events
@using static Moeltid.Services.TimeZoneHelper
@inject IEventService EventService

<PageTitle>Events — Consid Måltid</PageTitle>

<h1>Events</h1>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_grouped is null || (_grouped.Ongoing.Count == 0 && _grouped.Past.Count == 0))
{
    <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">📅</div>
        <h3>No events yet</h3>
        <p><a href="/new">Create your first event</a> to get started.</p>
    </div>
}
else
{
    @if (_grouped.Ongoing.Count > 0)
    {
        <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Orders</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _grouped.Ongoing)
                {
                    <tr style="cursor:pointer" @onclick="() => GoToEvent(row.Event.Slug)">
                        <td>@row.Event.Title</td>
                        <td class="text-muted"><small>@ToLocalString(row.Event.StartsAt, row.Event.TimeZoneId, "yyyy-MM-dd HH:mm") (@row.Event.TimeZoneId)</small></td>
                        <td><span class="badge text-bg-secondary">@row.OrderedCount</span></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
    else
    {
        <p class="text-muted">No upcoming events.</p>
    }

    @if (_grouped.Past.Count > 0)
    {
        <details class="mt-4">
            <summary class="text-muted" style="cursor:pointer">
                Past events (@_grouped.Past.Count)
            </summary>
            <div class="table-responsive">
            <table class="table table-sm table-hover mt-2">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Orders</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _grouped.Past)
                    {
                        <tr style="cursor:pointer" @onclick="() => GoToEvent(row.Event.Slug)">
                            <td>@row.Event.Title</td>
                            <td class="text-muted"><small>@ToLocalString(row.Event.StartsAt, row.Event.TimeZoneId, "yyyy-MM-dd HH:mm") (@row.Event.TimeZoneId)</small></td>
                            <td><span class="badge text-bg-secondary">@row.OrderedCount</span></td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </details>
    }
}

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _loading = true;
    private PublicEventGrouping.Result? _grouped;

    protected override async Task OnInitializedAsync()
    {
        var rows = await EventService.ListPublicAsync();
        _grouped = PublicEventGrouping.Build(rows);
        _loading = false;
    }

    // forceLoad required: EventPage calls Antiforgery.GetAndStoreTokens() during render,
    // which writes a Set-Cookie header. Soft Blazor navigation reuses the existing SignalR
    // circuit's already-sent HTTP response, so the cookie write throws "Headers are read-only".
    // Same pattern as GoToEditOrder in EventPage.razor.
    private void GoToEvent(string slug) => Nav.NavigateTo($"/e/{slug}", forceLoad: true);
}
