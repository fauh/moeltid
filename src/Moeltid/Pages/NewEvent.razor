@page "/new"
@using Moeltid.Models
@using Moeltid.Services.Events
@inject IEventService EventService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>New event — Consid Måltid</PageTitle>

<h1>Create an event</h1>

<EditForm Model="@model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="title">Event title <span class="text-danger">*</span></label>
        <InputText id="title" class="form-control" @bind-Value="model.Title" placeholder="e.g. Friday lunch" />
        <ValidationMessage For="@(() => model.Title)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="description">Description</label>
        <InputTextArea id="description" class="form-control" @bind-Value="model.Description" rows="3"
            placeholder="Optional details about the event" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="startsAt">Event date &amp; time <span class="text-danger">*</span></label>
        <InputDate id="startsAt" class="form-control" Type="InputDateType.DateTimeLocal"
            @bind-Value="model.StartsAt" />
        <ValidationMessage For="@(() => model.StartsAt)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="deadline">Order deadline <span class="text-danger">*</span></label>
        <InputDate id="deadline" class="form-control" Type="InputDateType.DateTimeLocal"
            @bind-Value="model.Deadline" />
        <ValidationMessage For="@(() => model.Deadline)" />
        <div class="form-text">Cut-off for submitting meal orders — usually a day or two before the event.</div>
    </div>

    <div class="mb-3">
        <label class="form-label" for="timezone">Your time zone</label>
        <input id="timezone" class="form-control" type="text" value="@model.TimeZoneId" readonly
            title="Detected from your browser" />
        <div class="form-text">Detected from your browser. Deadlines will be shown in this time zone.</div>
    </div>

    <div class="mb-3">
        <label class="form-label" for="ownerName">Your name <span class="text-danger">*</span></label>
        <InputText id="ownerName" class="form-control" @bind-Value="model.OwnerName" />
        <ValidationMessage For="@(() => model.OwnerName)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="ownerEmail">Your email <span class="text-danger">*</span></label>
        <InputText id="ownerEmail" class="form-control" @bind-Value="model.OwnerEmail" type="email"
            placeholder="The manage link will be emailed here" />
        <ValidationMessage For="@(() => model.OwnerEmail)" />
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox id="allowFreeText" class="form-check-input" @bind-Value="model.AllowFreeText" />
        <label class="form-check-label" for="allowFreeText">Allow free-text meal orders</label>
        <div class="form-text">When enabled, attendees can type their own order instead of choosing a preset.</div>
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox id="attendeeOrdersVisible" class="form-check-input" @bind-Value="model.AttendeeOrdersVisible" />
        <label class="form-check-label" for="attendeeOrdersVisible">Show all orders to attendees</label>
        <div class="form-text">When enabled, attendees can see each other's names and orders on the event page.</div>
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox id="isPrivate" class="form-check-input" @bind-Value="model.IsPrivate" />
        <label class="form-check-label" for="isPrivate">Private event (link-only)</label>
        <div class="form-text">When ticked, this event won't appear in the public browse list. Only people with the direct link can see it.</div>
    </div>

    @* ── Preset meal options ──────────────────────────────────────────────── *@
    <hr class="my-4" />
    <h2 class="h5">Preset meal options <span class="text-muted fw-normal fs-6">(optional)</span></h2>
    <p class="text-muted small">Define meal choices for attendees to pick from. You can add more after creation too.</p>

    @if (draftOptions.Count > 0)
    {
        <ul class="list-group mb-3">
            @foreach (var (draft, idx) in draftOptions.Select((d, i) => (d, i)))
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>
                        @draft.Label
                        @if (draft.Tags != MealTag.None)
                        {
                            <small class="text-muted ms-2">(@draft.Tags)</small>
                        }
                    </span>
                    <button type="button" class="btn btn-sm btn-outline-danger"
                            @onclick="() => RemoveDraftOption(idx)">Remove</button>
                </li>
            }
        </ul>
    }

    <div class="d-flex gap-2 align-items-end flex-wrap mb-2">
        <div>
            <label class="form-label mb-1">Label</label>
            <input class="form-control form-control-sm" style="width:220px" @bind="newOptionLabel"
                   placeholder="e.g. Vegetarian pasta" />
        </div>
        <button type="button" class="btn btn-sm btn-outline-primary"
                @onclick="AddDraftOption"
                disabled="@string.IsNullOrWhiteSpace(newOptionLabel)">Add option</button>
    </div>
    <div class="mb-3">
        @foreach (var tag in AllTags)
        {
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="new-opt-tag-@tag"
                       checked="@(newOptionTags.HasFlag(tag))"
                       @onchange="e => ToggleNewOptionTag(tag, (bool)e.Value!)" />
                <label class="form-check-label" for="new-opt-tag-@tag">@tag</label>
            </div>
        }
    </div>

    @* ── Invite by email ──────────────────────────────────────────────────── *@
    <hr class="my-4" />
    <h2 class="h5">Invite by email <span class="text-muted fw-normal fs-6">(optional)</span></h2>
    <p class="text-muted small">
        Each person gets an invitation email with a link that pre-fills their email on the order form.
        Separate multiple addresses with commas.
    </p>

    <div class="mb-3" style="max-width:500px">
        <label class="form-label" for="inviteeEmails">Email addresses</label>
        <InputTextArea id="inviteeEmails" class="form-control" @bind-Value="model.InviteeEmailsRaw" rows="3"
            placeholder="alice@example.com, bob@example.com" />
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
        @(isSubmitting ? "Creating…" : "Create event")
    </button>
</EditForm>

@code {
    private readonly FormModel model = new();
    private string? errorMessage;
    private bool isSubmitting;

    // ── draft meal options ────────────────────────────────────────────────
    private readonly List<MealOptionDraft> draftOptions = [];
    private string newOptionLabel = string.Empty;
    private MealTag newOptionTags;
    private static readonly MealTag[] AllTags =
        Enum.GetValues<MealTag>().Where(t => t != MealTag.None).ToArray();

    private void AddDraftOption()
    {
        if (string.IsNullOrWhiteSpace(newOptionLabel)) return;
        draftOptions.Add(new MealOptionDraft(newOptionLabel.Trim(), newOptionTags));
        newOptionLabel = string.Empty;
        newOptionTags = MealTag.None;
    }

    private void RemoveDraftOption(int index) => draftOptions.RemoveAt(index);

    private void ToggleNewOptionTag(MealTag tag, bool on) =>
        newOptionTags = on ? (newOptionTags | tag) : (newOptionTags & ~tag);

    // ── lifecycle ────────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var tz = await JS.InvokeAsync<string>("eval", "Intl.DateTimeFormat().resolvedOptions().timeZone");
            if (!string.IsNullOrWhiteSpace(tz))
                model.TimeZoneId = tz;
        }
        catch
        {
            // JS interop can fail during prerender — UTC fallback stays
        }
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        try
        {
            var inviteeEmails = (model.InviteeEmailsRaw ?? string.Empty)
                .Split([',', '\n', '\r'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(e => !string.IsNullOrWhiteSpace(e))
                .ToList();

            var ev = await EventService.CreateAsync(new CreateEventRequest(
                Title: model.Title,
                Description: model.Description,
                StartsAt: model.StartsAt,
                Deadline: model.Deadline,
                TimeZoneId: model.TimeZoneId,
                OwnerName: model.OwnerName,
                OwnerEmail: model.OwnerEmail,
                AllowFreeText: model.AllowFreeText,
                AttendeeOrdersVisible: model.AttendeeOrdersVisible,
                MealOptions: draftOptions,
                InviteeEmails: inviteeEmails,
                IsPrivate: model.IsPrivate
            ));
            Nav.NavigateTo($"/created/{ev.Id}");
        }
        catch
        {
            errorMessage = "Something went wrong creating the event. Please try again.";
            isSubmitting = false;
        }
    }

    private sealed class FormModel : System.ComponentModel.DataAnnotations.IValidatableObject
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Title is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Title { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.MaxLength(2000)]
        public string? Description { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Event date is required.")]
        public DateTime StartsAt { get; set; } = DateTime.Today.AddDays(7).AddHours(12);

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Deadline is required.")]
        public DateTime Deadline { get; set; } = DateTime.Today.AddDays(6).AddHours(12);

        public string TimeZoneId { get; set; } = "UTC";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Your name is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string OwnerName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Your email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email address.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string OwnerEmail { get; set; } = string.Empty;

        public bool AllowFreeText { get; set; } = true;
        public bool AttendeeOrdersVisible { get; set; } = true;
        public bool IsPrivate { get; set; }

        // Raw comma/newline-separated invite emails from the textarea
        public string? InviteeEmailsRaw { get; set; }

        public IEnumerable<System.ComponentModel.DataAnnotations.ValidationResult> Validate(
            System.ComponentModel.DataAnnotations.ValidationContext context)
        {
            if (Deadline >= StartsAt)
                yield return new System.ComponentModel.DataAnnotations.ValidationResult(
                    "Order deadline must be before the event date.",
                    [nameof(Deadline)]);
        }
    }
}
