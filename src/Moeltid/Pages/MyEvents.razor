@page "/my-events"
@using Moeltid.Services.MyEvents
@inject IMyEventsService MyEventsService
@inject NavigationManager Nav

<PageTitle>My Events — Consid Måltid</PageTitle>

<h1>My Events</h1>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_showList)
{
    <!-- Token was valid; show the event list -->
    @if (_rows.Count == 0)
    {
        <div class="alert alert-info">No events found for your email address.</div>
    }
    else
    {
        var ongoing = _rows.Where(r => r.IsOngoing).ToList();
        var past = _rows.Where(r => !r.IsOngoing).ToList();

        @if (ongoing.Count > 0)
        {
            <h2 class="h5 mt-3">Upcoming events</h2>
            <table class="table table-sm">
                <thead>
                    <tr><th>Event</th><th>Date</th><th>Your role</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var row in ongoing)
                    {
                        <tr>
                            <td>@row.Event.Title</td>
                            <td class="text-muted"><small>@FormatDate(row.Event)</small></td>
                            <td>@RoleBadges(row.Roles)</td>
                            <td><a href="@row.ActionUrl" class="btn btn-sm btn-outline-primary">Open</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted mt-3">No upcoming events.</p>
        }

        @if (past.Count > 0)
        {
            <details class="mt-4">
                <summary class="text-muted" style="cursor:pointer">
                    Past events (@past.Count)
                </summary>
                <table class="table table-sm mt-2">
                    <thead>
                        <tr><th>Event</th><th>Date</th><th>Your role</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var row in past)
                        {
                            <tr>
                                <td>@row.Event.Title</td>
                                <td class="text-muted"><small>@FormatDate(row.Event)</small></td>
                                <td>@RoleBadges(row.Roles)</td>
                                <td><a href="@row.ActionUrl" class="btn btn-sm btn-outline-secondary">Open</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </details>
        }
    }
}
else if (_tokenInvalid)
{
    <!-- Token was present but invalid/expired/used -->
    <div class="alert alert-warning">
        <strong>This link has expired or has already been used.</strong>
        Request a new one below.
    </div>
    @RequestForm()
}
else
{
    <!-- No token — show the request form -->
    @RequestForm()
}

@code {
    [SupplyParameterFromQuery(Name = "t")] public string? Token { get; set; }

    private bool _loading;
    private bool _showList;
    private bool _tokenInvalid;
    private bool _requestSent;
    private bool _requestError;
    private string _emailInput = string.Empty;
    private bool _submitting;
    private IReadOnlyList<MyEventRow> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Token)) return;

        _loading = true;
        var email = await MyEventsService.ValidateAndConsumeAsync(Token);
        _loading = false;

        if (email is null)
        {
            _tokenInvalid = true;
            return;
        }

        _rows = await MyEventsService.GetEventsForEmailAsync(email);
        _showList = true;
    }

    private async Task SubmitRequestAsync()
    {
        _requestError = false;
        _submitting = true;
        try
        {
            await MyEventsService.RequestAccessAsync(_emailInput.Trim());
            _requestSent = true;
        }
        catch (ArgumentException)
        {
            _requestError = true;
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string FormatDate(Moeltid.Models.Event ev)
    {
        try
        {
            var tz = TimeZoneInfo.FindSystemTimeZoneById(ev.TimeZoneId);
            var local = TimeZoneInfo.ConvertTime(ev.StartsAt, tz);
            return $"{local:yyyy-MM-dd HH:mm} ({ev.TimeZoneId})";
        }
        catch
        {
            return ev.StartsAt.ToString("yyyy-MM-dd HH:mm") + " UTC";
        }
    }

    private static RenderFragment RoleBadges(EventRole roles) => __builder =>
    {
        var sequence = 0;

        if (roles.HasFlag(EventRole.Owner))
        {
            __builder.OpenElement(sequence++, "span");
            __builder.AddAttribute(sequence++, "class", "badge text-bg-primary me-1");
            __builder.AddContent(sequence++, "owner");
            __builder.CloseElement();
        }

        if (roles.HasFlag(EventRole.Attendee))
        {
            __builder.OpenElement(sequence++, "span");
            __builder.AddAttribute(sequence++, "class", "badge text-bg-success me-1");
            __builder.AddContent(sequence++, "attendee");
            __builder.CloseElement();
        }

        if (roles.HasFlag(EventRole.Invitee))
        {
            __builder.OpenElement(sequence++, "span");
            __builder.AddAttribute(sequence++, "class", "badge text-bg-secondary me-1");
            __builder.AddContent(sequence++, "invitee");
            __builder.CloseElement();
        }
    };

    private RenderFragment RequestForm() => __builder =>
    {
        if (_requestSent)
        {
            <div class="alert alert-success">
                If your email matches any events, you'll receive a link shortly. Check your inbox.
            </div>
        }
        else
        {
            <p class="text-muted">Enter your email address and we'll send you a link to view all events tied to it.</p>

            @if (_requestError)
            {
                <div class="alert alert-danger py-2">Please enter a valid email address.</div>
            }

            <div class="d-flex gap-2 align-items-end" style="max-width:420px">
                <div class="flex-grow-1">
                    <label class="form-label mb-1" for="email-input">Email address</label>
                    <input id="email-input" type="email" class="form-control"
                           @bind="_emailInput" placeholder="you@example.com" />
                </div>
                <button class="btn btn-primary" @onclick="SubmitRequestAsync"
                        disabled="@(string.IsNullOrWhiteSpace(_emailInput) || _submitting)">
                    @(_submitting ? "Sending…" : "Send link")
                </button>
            </div>
        }
    };
}
