@page "/created/{EventId:guid}"
@using Moeltid.Models
@using Moeltid.Services.Events
@using static Moeltid.Services.TimeZoneHelper
@inject IEventService EventService
@inject NavigationManager Nav

<PageTitle>Event created — Consid Måltid</PageTitle>

@if (notFound)
{
    <h1>Event not found</h1>
    <p>This link doesn't resolve to an event. The event may have been removed, or the link may be wrong.</p>
    <a href="/" class="btn btn-outline-secondary">Back to home</a>
}
else if (ev is null)
{
    <p>Loading…</p>
}
else
{
    <h1>Event created!</h1>

    <div class="alert alert-success">
        <h4 class="alert-heading">Save your manage link</h4>
        <p>This is the only way to edit your event and view orders. It was also emailed to <strong>@ev.OwnerEmail</strong>.</p>
        <hr />
        <p class="mb-0 fw-bold text-break">
            <a href="@ManageUrl">@ManageUrl</a>
        </p>
    </div>

    <h2 class="mt-4">@ev.Title</h2>
    @if (!string.IsNullOrEmpty(ev.Description))
    {
        <p>@ev.Description</p>
    }
    <p><strong>Event date:</strong> @ToLocalString(ev.StartsAt, ev.TimeZoneId)</p>
    <p>
        <strong>Public event URL:</strong><br />
        <a href="/e/@ev.Slug" @onclick:preventDefault @onclick="GoToPublicPage">/e/@ev.Slug</a>
    </p>
    <p class="text-muted">Share the public URL with attendees. Share the manage link only with people you want to co-administer this event.</p>
}

@code {
    [Parameter] public Guid EventId { get; set; }

    private Event? ev;
    private bool notFound;
    private string ManageUrl => ev is null ? string.Empty
        : Nav.ToAbsoluteUri($"/e/{ev.Slug}/manage?t={ev.ManageToken}").ToString();

    protected override async Task OnInitializedAsync()
    {
        ev = await EventService.GetByIdAsync(EventId);
        notFound = ev is null;
    }

    // forceLoad is required because /e/{slug} renders a form that depends on
    // HttpContext (for antiforgery tokens). Soft-nav inside the SignalR circuit
    // leaves HttpContext null and the form silently fails to render.
    private void GoToPublicPage()
    {
        if (ev is not null) Nav.NavigateTo($"/e/{ev.Slug}", forceLoad: true);
    }
}
