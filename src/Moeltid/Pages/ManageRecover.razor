@page "/e/{Slug}/manage/recover"
@inject NavigationManager Nav

@*
  Legacy route — superseded by the top-level /recover page on 2026-05-06.
  Kept as a redirect stub so any inbound bookmarks or emailed links from
  before the move still land somewhere useful. Safe to delete this file
  once we're confident no live URLs point here.
*@

<PageTitle>Redirecting — Consid Måltid</PageTitle>

<p>Redirecting to the recover page…</p>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) Nav.NavigateTo("/recover", forceLoad: true);
    }
}
